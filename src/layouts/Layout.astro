---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
}

const { title = 'Yablid' } = Astro.props;
const pageTitle = title === 'Yablid' ? 'Yablid' : `Yablid - ${title}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="data:," />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<div class="page-wrapper">
			<header class="page-section">
				<Navbar />
			</header>
			<main class="page-main page-section">
				<slot />
			</main>
			<footer class="page-section">
				<Footer />
			</footer>
		</div>
	</body>
</html>

<style>
	html,
	body {
		width: 100%;
		min-height: 100%;
	}

	.page-wrapper {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.page-section {
		width: 100%;
		max-width: var(--max-width-text);
		margin: 0 auto;
		padding: var(--space-2);
	}

	.page-main {
		flex: 1;
	}
</style>
