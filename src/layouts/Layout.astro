---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const defaultDescription = 'Applied AI engineering and consulting. Projects, thoughts, and tools by Yablid.';
const { title = 'Yablid', description = defaultDescription, wide = false } = Astro.props;
const pageTitle = title === 'Yablid' ? 'Yablid' : `Yablid - ${title}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://yablid.com').href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="data:," />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Yablid" />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
	</head>
	<body class:list={[{ 'is-wide': wide }]}>
		<div class="page-wrapper">
			<header class="page-section">
				<Navbar />
			</header>
			<main class="page-main page-section">
				<slot />
			</main>
			<footer class="page-section">
				<Footer />
			</footer>
		</div>
	</body>
</html>

<style>
	html,
	body {
		width: 100%;
		min-height: 100%;
	}

	.page-wrapper {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.page-section {
		width: 100%;
		max-width: var(--max-width-text);
		margin: 0 auto;
		padding: var(--space-2);
	}

	body.is-wide .page-section {
		max-width: var(--max-width-prose, 92ch);
	}

	.page-main {
		flex: 1;
	}
</style>
