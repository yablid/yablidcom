---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CollectionList from '../../components/CollectionList.astro';

const projects = await getCollection('projects');

type ProjectEntry = typeof projects[number];

const grouped = projects.reduce((acc, entry) => {
	const section = entry.data.section || 'Other';
	if (!acc[section]) {
		acc[section] = [];
	}
	acc[section].push(entry);
	return acc;
}, {} as Record<string, ProjectEntry[]>);

const sections = Object.entries(grouped);
---

<Layout title="Projects">
	<CollectionList title="Projects" sections={sections} basePath="projects" showGitHub />
</Layout>
